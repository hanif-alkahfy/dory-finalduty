# ─── Server ───────────────────────────────────────────────────────────────
PORT=3000

# ─── Database MySQL ────────────────────────────────────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=dorymind

# ─── JWT ──────────────────────────────────────────────────────────────────
# Ganti dengan string acak yang panjang dan aman
# Contoh generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=ganti_dengan_string_acak_panjang

# ─── Admin Default (digunakan oleh: npm run setup) ────────────────────────
# Akun admin yang dibuat saat pertama kali setup database
# Segera ganti password setelah login pertama!
ADMIN_EMAIL=admin@dorymind.com
ADMIN_PASSWORD=admin123

# ─── WhatsApp (Opsional) ──────────────────────────────────────────────────
# Path ke executable Chrome/Chromium jika ingin menggunakan browser custom
# Kosongkan untuk menggunakan browser bawaan puppeteer (default)
# Contoh Windows: C:\Program Files\Google\Chrome\Application\chrome.exe
CHROME_PATH=
